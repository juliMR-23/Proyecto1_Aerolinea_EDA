<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="1080.0" prefWidth="1920.0"
            style="-fx-background-color: #1E2A35;"
            xmlns="http://javafx.com/javafx/23"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controller.InfoVueloEspecificoPilotoViewController">

    <ScrollPane fitToWidth="true"
                style="-fx-background: transparent;
                       -fx-background-color: transparent;
                       -fx-border-color: transparent;"
                AnchorPane.topAnchor="0.0" AnchorPane.bottomAnchor="0.0"
                AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0">

        <VBox alignment="TOP_CENTER" spacing="36.0"
              style="-fx-padding: 100 160 60 160;">

            <!-- Título -->
            <VBox alignment="CENTER" spacing="8.0">
                <Label text="Detalle del Vuelo"
                       style="-fx-font-size: 36px; -fx-font-weight: bold;
                              -fx-text-fill: #ECF0F1;"/>
                <Label fx:id="lblRutaTitulo" text=""
                       style="-fx-font-size: 18px; -fx-text-fill: #C9A84C;"/>
            </VBox>

            <!-- Estado y duración -->
            <HBox alignment="CENTER" spacing="24.0" maxWidth="1400.0">

                <!-- Estado -->
                <VBox alignment="CENTER" spacing="8.0" prefWidth="300.0"
                      style="-fx-background-color: #FFFFFF;
                             -fx-background-radius: 16;
                             -fx-padding: 32 24 32 24;
                             -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.10), 12, 0, 3, 3);">
                    <Label text="Estado actual"
                           style="-fx-font-size: 13px; -fx-text-fill: #888888;
                                  -fx-font-weight: bold;"/>
                    <Label fx:id="lblEstado" text=""
                           style="-fx-font-size: 22px; -fx-font-weight: bold;
                                  -fx-text-fill: white;
                                  -fx-padding: 8 24 8 24;
                                  -fx-background-radius: 20;"/>
                </VBox>

                <!-- Duración -->
                <VBox alignment="CENTER" spacing="8.0" prefWidth="300.0"
                      style="-fx-background-color: #FFFFFF;
                             -fx-background-radius: 16;
                             -fx-padding: 32 24 32 24;
                             -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.10), 12, 0, 3, 3);">
                    <Label text="⏱"
                           style="-fx-font-size: 36px; -fx-text-fill: #C9A84C;"/>
                    <Label fx:id="lblDuracion" text=""
                           style="-fx-font-size: 36px; -fx-font-weight: bold;
                                  -fx-text-fill: #1E2A35;"/>
                    <Label text="Duración del vuelo"
                           style="-fx-font-size: 13px; -fx-text-fill: #888888;
                                  -fx-font-weight: bold;"/>
                </VBox>

                <!-- Puerta de embarque -->
                <VBox alignment="CENTER" spacing="8.0" prefWidth="300.0"
                      style="-fx-background-color: #FFFFFF;
                             -fx-background-radius: 16;
                             -fx-padding: 32 24 32 24;
                             -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.10), 12, 0, 3, 3);">
                    <Label text="🚪"
                           style="-fx-font-size: 36px; -fx-text-fill: #C9A84C;"/>
                    <Label fx:id="lblPuerta" text=""
                           style="-fx-font-size: 36px; -fx-font-weight: bold;
                                  -fx-text-fill: #1E2A35;"/>
                    <Label text="Puerta de embarque"
                           style="-fx-font-size: 13px; -fx-text-fill: #888888;
                                  -fx-font-weight: bold;"/>
                </VBox>

                <!-- Avión -->
                <VBox alignment="CENTER" spacing="8.0" prefWidth="300.0"
                      style="-fx-background-color: #FFFFFF;
                             -fx-background-radius: 16;
                             -fx-padding: 32 24 32 24;
                             -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.10), 12, 0, 3, 3);">
                    <Label text="✈"
                           style="-fx-font-size: 36px; -fx-text-fill: #C9A84C;"/>
                    <Label fx:id="lblAvion" text=""
                           style="-fx-font-size: 22px; -fx-font-weight: bold;
                                  -fx-text-fill: #1E2A35;"/>
                    <Label fx:id="lblMatricula" text=""
                           style="-fx-font-size: 13px; -fx-text-fill: #888888;"/>
                </VBox>

            </HBox>

            <!-- Origen y Destino -->
            <HBox alignment="CENTER" spacing="24.0" maxWidth="1400.0">

                <!-- Origen -->
                <VBox spacing="0.0" HBox.hgrow="ALWAYS"
                      style="-fx-background-color: #FFFFFF;
                             -fx-background-radius: 16;
                             -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.10), 12, 0, 3, 3);">

                    <!-- Header origen -->
                    <HBox alignment="CENTER_LEFT"
                          style="-fx-background-color: #1E2A35;
                                 -fx-background-radius: 16 16 0 0;
                                 -fx-padding: 16 32 16 32;">
                        <Label text="🛫  Aeropuerto de Origen"
                               style="-fx-font-size: 16px; -fx-font-weight: bold;
                                      -fx-text-fill: #C9A84C;"/>
                    </HBox>

                    <!-- Body origen -->
                    <VBox spacing="16.0"
                          style="-fx-padding: 24 32 24 32;">
                        <HBox spacing="40.0">
                            <VBox fx:id="boxOrigenNombre" spacing="4.0" prefWidth="300.0"/>
                            <VBox fx:id="boxOrigenCiudad"  spacing="4.0" prefWidth="220.0"/>
                            <VBox fx:id="boxOrigenPais"    spacing="4.0" prefWidth="220.0"/>
                        </HBox>
                        <HBox spacing="40.0">
                            <VBox fx:id="boxOrigenZona"    spacing="4.0" prefWidth="220.0"/>
                            <VBox fx:id="boxOrigenSalida"  spacing="4.0" prefWidth="300.0"/>
                        </HBox>
                    </VBox>
                </VBox>

                <!-- Destino -->
                <VBox spacing="0.0" HBox.hgrow="ALWAYS"
                      style="-fx-background-color: #FFFFFF;
                             -fx-background-radius: 16;
                             -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.10), 12, 0, 3, 3);">

                    <!-- Header destino -->
                    <HBox alignment="CENTER_LEFT"
                          style="-fx-background-color: #1E2A35;
                                 -fx-background-radius: 16 16 0 0;
                                 -fx-padding: 16 32 16 32;">
                        <Label text="🛬  Aeropuerto de Destino"
                               style="-fx-font-size: 16px; -fx-font-weight: bold;
                                      -fx-text-fill: #C9A84C;"/>
                    </HBox>

                    <!-- Body destino -->
                    <VBox spacing="16.0"
                          style="-fx-padding: 24 32 24 32;">
                        <HBox spacing="40.0">
                            <VBox fx:id="boxDestinoNombre"  spacing="4.0" prefWidth="300.0"/>
                            <VBox fx:id="boxDestinoCiudad"  spacing="4.0" prefWidth="220.0"/>
                            <VBox fx:id="boxDestinoPais"    spacing="4.0" prefWidth="220.0"/>
                        </HBox>
                        <HBox spacing="40.0">
                            <VBox fx:id="boxDestinoZona"    spacing="4.0" prefWidth="220.0"/>
                            <VBox fx:id="boxDestinoLlegada" spacing="4.0" prefWidth="300.0"/>
                        </HBox>
                    </VBox>
                </VBox>

            </HBox>

            <!-- Volver -->
            <Button fx:id="btnVolver"
                    text="← Volver al panel"
                    onAction="#handleVolver"
                    style="-fx-background-color: transparent;
                           -fx-text-fill: #7F8C8D;
                           -fx-font-size: 15px;
                           -fx-border-color: transparent;
                           -fx-cursor: hand;"/>

        </VBox>
    </ScrollPane>

    <Label text="✈  EDArolinea"
           style="-fx-text-fill: #C9A84C; -fx-font-size: 24px; -fx-font-weight: bold;"
           AnchorPane.topAnchor="28.0" AnchorPane.leftAnchor="48.0"/>

</AnchorPane>
