<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.Region?>

<AnchorPane prefHeight="1080.0" prefWidth="1920.0"
            style="-fx-background-color: #1E2A35;"
            xmlns="http://javafx.com/javafx/23"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controller.MainPageAdminViewController">

    <VBox alignment="TOP_CENTER" spacing="48.0"
          style="-fx-padding: 100 160 60 160;"
          AnchorPane.topAnchor="0.0" AnchorPane.bottomAnchor="0.0"
          AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0">

        <!-- Título -->
        <VBox alignment="CENTER" spacing="8.0">
            <Label text="Panel de Administración"
                   style="-fx-font-size: 36px; -fx-font-weight: bold;
                          -fx-text-fill: #ECF0F1;"/>
            <Label fx:id="lblSubtitulo" text=""
                   style="-fx-font-size: 16px; -fx-text-fill: #C9A84C;"/>
        </VBox>

        <!-- Fila 1: Aeropuertos y Aviones -->
        <HBox alignment="CENTER" spacing="32.0">

            <VBox alignment="CENTER" spacing="16.0" prefWidth="380.0"
                  style="-fx-background-color: #FFFFFF;
                         -fx-background-radius: 20;
                         -fx-padding: 40 32 40 32;
                         -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.10), 12, 0, 3, 3);">
                <Label text="🛫"
                       style="-fx-font-size: 48px;"/>
                <Label text="Aeropuertos"
                       style="-fx-font-size: 22px; -fx-font-weight: bold;
                              -fx-text-fill: #1E2A35;"/>
                <Label text="Crear, editar y eliminar aeropuertos"
                       style="-fx-font-size: 13px; -fx-text-fill: #888888;
                              -fx-text-alignment: center;" wrapText="true"/>
                <Button text="Gestionar Aeropuertos"
                        onAction="#handleAeropuertos"
                        prefWidth="260.0" prefHeight="48.0"
                        style="-fx-background-color: #1E2A35;
                               -fx-text-fill: #C9A84C;
                               -fx-font-size: 15px;
                               -fx-font-weight: bold;
                               -fx-background-radius: 10;
                               -fx-cursor: hand;"/>
            </VBox>

            <VBox alignment="CENTER" spacing="16.0" prefWidth="380.0"
                  style="-fx-background-color: #FFFFFF;
                         -fx-background-radius: 20;
                         -fx-padding: 40 32 40 32;
                         -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.10), 12, 0, 3, 3);">
                <Label text="✈"
                       style="-fx-font-size: 48px;"/>
                <Label text="Aviones"
                       style="-fx-font-size: 22px; -fx-font-weight: bold;
                              -fx-text-fill: #1E2A35;"/>
                <Label text="Registrar y administrar la flota"
                       style="-fx-font-size: 13px; -fx-text-fill: #888888;
                              -fx-text-alignment: center;" wrapText="true"/>
                <Button text="Gestionar Aviones"
                        onAction="#handleAviones"
                        prefWidth="260.0" prefHeight="48.0"
                        style="-fx-background-color: #1E2A35;
                               -fx-text-fill: #C9A84C;
                               -fx-font-size: 15px;
                               -fx-font-weight: bold;
                               -fx-background-radius: 10;
                               -fx-cursor: hand;"/>
            </VBox>

            <VBox alignment="CENTER" spacing="16.0" prefWidth="380.0"
                  style="-fx-background-color: #FFFFFF;
                         -fx-background-radius: 20;
                         -fx-padding: 40 32 40 32;
                         -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.10), 12, 0, 3, 3);">
                <Label text="🗓"
                       style="-fx-font-size: 48px;"/>
                <Label text="Vuelos"
                       style="-fx-font-size: 22px; -fx-font-weight: bold;
                              -fx-text-fill: #1E2A35;"/>
                <Label text="Programar, modificar y cancelar vuelos"
                       style="-fx-font-size: 13px; -fx-text-fill: #888888;
                              -fx-text-alignment: center;" wrapText="true"/>
                <Button text="Gestionar Vuelos"
                        onAction="#handleVuelos"
                        prefWidth="260.0" prefHeight="48.0"
                        style="-fx-background-color: #1E2A35;
                               -fx-text-fill: #C9A84C;
                               -fx-font-size: 15px;
                               -fx-font-weight: bold;
                               -fx-background-radius: 10;
                               -fx-cursor: hand;"/>
            </VBox>

        </HBox>

        <!-- Fila 2: Personas -->
        <HBox alignment="CENTER" spacing="32.0">

            <VBox alignment="CENTER" spacing="16.0" prefWidth="380.0"
                  style="-fx-background-color: #FFFFFF;
                         -fx-background-radius: 20;
                         -fx-padding: 40 32 40 32;
                         -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.10), 12, 0, 3, 3);">
                <Label text="👤"
                       style="-fx-font-size: 48px;"/>
                <Label text="Clientes"
                       style="-fx-font-size: 22px; -fx-font-weight: bold;
                              -fx-text-fill: #1E2A35;"/>
                <Label text="Ver y gestionar los clientes registrados"
                       style="-fx-font-size: 13px; -fx-text-fill: #888888;
                              -fx-text-alignment: center;" wrapText="true"/>
                <Button text="Gestionar Clientes"
                        onAction="#handleClientes"
                        prefWidth="260.0" prefHeight="48.0"
                        style="-fx-background-color: #1E2A35;
                               -fx-text-fill: #C9A84C;
                               -fx-font-size: 15px;
                               -fx-font-weight: bold;
                               -fx-background-radius: 10;
                               -fx-cursor: hand;"/>
            </VBox>

            <VBox alignment="CENTER" spacing="16.0" prefWidth="380.0"
                  style="-fx-background-color: #FFFFFF;
                         -fx-background-radius: 20;
                         -fx-padding: 40 32 40 32;
                         -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.10), 12, 0, 3, 3);">
                <Label text="🧑‍✈️"
                       style="-fx-font-size: 48px;"/>
                <Label text="Pilotos"
                       style="-fx-font-size: 22px; -fx-font-weight: bold;
                              -fx-text-fill: #1E2A35;"/>
                <Label text="Registrar y gestionar pilotos activos"
                       style="-fx-font-size: 13px; -fx-text-fill: #888888;
                              -fx-text-alignment: center;" wrapText="true"/>
                <Button text="Gestionar Pilotos"
                        onAction="#handlePilotos"
                        prefWidth="260.0" prefHeight="48.0"
                        style="-fx-background-color: #1E2A35;
                               -fx-text-fill: #C9A84C;
                               -fx-font-size: 15px;
                               -fx-font-weight: bold;
                               -fx-background-radius: 10;
                               -fx-cursor: hand;"/>
            </VBox>

            <VBox alignment="CENTER" spacing="16.0" prefWidth="380.0"
                  style="-fx-background-color: #FFFFFF;
                         -fx-background-radius: 20;
                         -fx-padding: 40 32 40 32;
                         -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.10), 12, 0, 3, 3);">
                <Label text="🧑‍🤝‍🧑"
                       style="-fx-font-size: 48px;"/>
                <Label text="Tripulantes de Cabina"
                       style="-fx-font-size: 22px; -fx-font-weight: bold;
                              -fx-text-fill: #1E2A35;"/>
                <Label text="Gestionar tripulantes y sus idiomas"
                       style="-fx-font-size: 13px; -fx-text-fill: #888888;
                              -fx-text-alignment: center;" wrapText="true"/>
                <Button text="Gestionar Tripulantes"
                        onAction="#handleTripulantes"
                        prefWidth="260.0" prefHeight="48.0"
                        style="-fx-background-color: #1E2A35;
                               -fx-text-fill: #C9A84C;
                               -fx-font-size: 15px;
                               -fx-font-weight: bold;
                               -fx-background-radius: 10;
                               -fx-cursor: hand;"/>
            </VBox>

        </HBox>

        <Region VBox.vgrow="ALWAYS"/>

        <Button fx:id="btnCerrarSesion"
                text="Cerrar sesión"
                onAction="#handleCerrarSesion"
                style="-fx-background-color: transparent;
                       -fx-text-fill: #7F8C8D;
                       -fx-font-size: 15px;
                       -fx-border-color: transparent;
                       -fx-cursor: hand;"/>

    </VBox>

    <Label text="✈  EDArolinea"
           style="-fx-text-fill: #C9A84C; -fx-font-size: 24px; -fx-font-weight: bold;"
           AnchorPane.topAnchor="28.0" AnchorPane.leftAnchor="48.0"/>

</AnchorPane>
