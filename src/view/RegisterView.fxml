<?xml version="1.0" encoding="UTF-8"?>

<?import io.github.palexdev.materialfx.controls.MFXButton?>
<?import io.github.palexdev.materialfx.controls.MFXPasswordField?>
<?import io.github.palexdev.materialfx.controls.MFXTextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.Label?>

<AnchorPane prefHeight="1080.0" prefWidth="1920.0"
            style="-fx-background-color: #1E2A35;"
            xmlns="http://javafx.com/javafx/23"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controller.RegisterViewController">

    <!-- Panel con formulario -->
    <VBox alignment="CENTER" spacing="20.0"
          style="-fx-background-color: #2C3E50; -fx-background-radius: 20; -fx-padding: 50;"
          prefWidth="740.0"
          AnchorPane.leftAnchor="590.0" AnchorPane.rightAnchor="590.0"
          AnchorPane.topAnchor="80.0" AnchorPane.bottomAnchor="80.0">

        <!-- Títulos -->
        <Label text="Crear Cuenta" styleClass="title-main"/>
        <Label text="Completa tus datos para registrarte" styleClass="title-sub"/>

        <!-- Ingresar nombre -->
        <MFXTextField fx:id="txtNombre"
                      promptText="Nombre completo"
                      prefWidth="480.0" prefHeight="68.0"
                      styleClass="field-main"/>

        <!-- Tipo de documento + Numero -->
        <HBox spacing="16.0" prefWidth="480.0">
            <MFXTextField fx:id="txtTipoDocumento"
                          promptText="Tipo documento (CC, CE, PAS)"
                          prefWidth="220.0" prefHeight="68.0"
                          styleClass="field-main"/>

            <MFXTextField fx:id="txtDocumento"
                          promptText="Número de documento"
                          prefWidth="244.0" prefHeight="68.0"
                          styleClass="field-main"/>
        </HBox>

        <!-- Telefono -->
        <MFXTextField fx:id="txtTelefono"
                      promptText="Teléfono"
                      prefWidth="480.0" prefHeight="68.0"
                      styleClass="field-main"/>

        <!-- Correo -->
        <MFXTextField fx:id="txtEmail"
                      promptText="Correo electrónico"
                      prefWidth="480.0" prefHeight="68.0"
                      styleClass="field-main"/>

        <!-- Contraseña -->
        <MFXPasswordField fx:id="txtPassword"
                          promptText="Contraseña"
                          prefWidth="480.0" prefHeight="68.0"
                          styleClass="field-main"/>

        <!-- Mensajes del try / catch -->
        <Label fx:id="lblMensaje"
               text=""
               styleClass="text-error"
               wrapText="true"/>

        <!-- Boton Registrar -->
        <MFXButton fx:id="btnRegistrar"
                   text="Crear Cuenta"
                   prefWidth="480.0" prefHeight="64.0"
                   onAction="#handleRegistrar"
                   styleClass="btn-primary"/>

        <!-- Boton Volver -->
        <MFXButton fx:id="btnVolver"
                   text="¿Ya tienes cuenta? Inicia Sesión"
                   prefWidth="480.0" prefHeight="52.0"
                   onAction="#handleVolver"
                   styleClass="btn-outline"/>
    </VBox>
</AnchorPane>