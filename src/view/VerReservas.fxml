<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="1080.0" prefWidth="1920.0"
            style="-fx-background-color: #1E2A35;"
            xmlns="http://javafx.com/javafx/23"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controller.VerReservasViewController">

    <ScrollPane fitToWidth="true"
                style="-fx-background: transparent;
                       -fx-background-color: transparent;
                       -fx-border-color: transparent;"
                AnchorPane.topAnchor="0.0" AnchorPane.bottomAnchor="0.0"
                AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0">

        <VBox alignment="TOP_CENTER" spacing="36.0"
              style="-fx-padding: 100 160 60 160;">

            <!-- Titulo -->
            <VBox alignment="CENTER" spacing="8.0">
                <Label text="Mis Reservas"
                       style="-fx-font-size: 36px; -fx-font-weight: bold;
                              -fx-text-fill: #ECF0F1;"/>
                <Label fx:id="lblSubtitulo" text=""
                       style="-fx-font-size: 16px; -fx-text-fill: #C9A84C;"/>
            </VBox>

            <!-- Proximas Reservas -->
            <VBox spacing="14.0" maxWidth="1400.0">
                <Label text="✈  Próximos vuelos"
                       style="-fx-font-size: 20px; -fx-font-weight: bold;
                              -fx-text-fill: #C9A84C;"/>
                <VBox fx:id="vboxProximos" spacing="14.0"/>
            </VBox>

            <!-- Reservas Pasadas -->
            <VBox spacing="14.0" maxWidth="1400.0">
                <Label text="🕓  Vuelos pasados"
                       style="-fx-font-size: 20px; -fx-font-weight: bold;
                              -fx-text-fill: #7F8C8D;"/>
                <VBox fx:id="vboxPasados" spacing="14.0"/>
            </VBox>

            <!-- Volver -->
            <Button fx:id="btnVolver"
                    text="← Volver"
                    onAction="#handleVolver"
                    style="-fx-background-color: transparent;
                           -fx-text-fill: #7F8C8D;
                           -fx-font-size: 15px;
                           -fx-border-color: transparent;
                           -fx-cursor: hand;"/>
        </VBox>
    </ScrollPane>

    <Label text="✈  EDArolinea"
           style="-fx-text-fill: #C9A84C; -fx-font-size: 24px; -fx-font-weight: bold;"
           AnchorPane.topAnchor="28.0" AnchorPane.leftAnchor="48.0"/>

</AnchorPane>